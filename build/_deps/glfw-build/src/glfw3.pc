prefix=/home/z/my-project/build/stub_x11
exec_prefix=${prefix}
includedir=/home/z/my-project/build/stub_x11/include
libdir=/home/z/my-project/build/stub_x11/lib

Name: GLFW
Description: A multi-platform library for OpenGL, window and input
Version: 3.3.9
URL: https://www.glfw.org/
Requires.private:  x11
Libs: -L${libdir} -lglfw3
Libs.private:  -lrt -lm -ldl
Cflags: -I${includedir}
